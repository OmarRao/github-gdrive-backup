# ─── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with scopes: repo, read:org, read:user
GITHUB_TOKEN=ghp_your_token_here

# GitHub username or organisation to back up (leave blank to back up ALL repos
# the token has access to)
GITHUB_USER=your_username_or_org

# ─── Google Drive ─────────────────────────────────────────────────────────────
# Path to the OAuth 2.0 client-secrets JSON downloaded from Google Cloud Console
GOOGLE_CLIENT_SECRET_PATH=./credentials/google-client-secret.json

# Where Drive tokens are cached after first OAuth consent
GOOGLE_TOKEN_PATH=./credentials/google-token.json

# Drive folder ID to store backups in (create a folder in Drive and copy its ID
# from the URL: drive.google.com/drive/folders/<ID>)
GDRIVE_FOLDER_ID=your_gdrive_folder_id

# ─── Backup behaviour ─────────────────────────────────────────────────────────
# Comma-separated list of extra items to include:
# code,issues,pull_requests,releases,wiki,labels,milestones
BACKUP_INCLUDE=code,issues,pull_requests,releases,wiki,labels,milestones

# Maximum number of parallel repo operations (lower = safer on rate limits)
BACKUP_CONCURRENCY=3

# Temporary working directory for staging archives before upload
BACKUP_TMP_DIR=./tmp

# Optional AES-256-CBC encryption at rest (64 hex chars = 32 bytes). Required
# for both backup (encrypt) and restore (decrypt) — store it in a secrets vault.
# BACKUP_ENCRYPTION_KEY=

# ─── Multi-destination fan-out (3-2-1 rule) ───────────────────────────────────
# Google Drive is always the PRIMARY destination. List any secondary clouds to
# mirror every archive/manifest/summary to. Valid values: s3, azure, b2.
# Each listed target's own credentials (below) must also be set.
# BACKUP_MIRROR_TARGETS=s3,b2

# Amazon S3 (target: s3)
# AWS_BUCKET_NAME=
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Azure Blob (target: azure)
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_CONTAINER_NAME=gh-backups

# Backblaze B2 (target: b2 — S3-compatible)
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_KEY_ID=
# B2_APP_KEY=
# B2_BUCKET=

# ─── Web UI server ────────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change_me_to_a_random_string
