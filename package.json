{
  "name": "github-gdrive-backup",
  "version": "1.0.0",
  "description": "Backup and restore all GitHub repositories and metadata to Google Drive",
  "main": "src/server/app.js",
  "bin": {
    "gh-gdrive-backup": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/server/app.js",
    "backup": "node src/backup/index.js",
    "restore": "node src/restore/index.js",
    "dev": "nodemon src/server/app.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.1",
    "archiver": "^7.0.1",
    "axios": "^1.7.9",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "extract-zip": "^2.0.1",
    "googleapis": "^144.0.0",
    "multer": "^2.2.0",
    "simple-git": "^3.27.0",
    "winston": "^3.17.0",
    "@aws-sdk/client-s3": "^3.600.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "keywords": [
    "github",
    "backup",
    "google-drive",
    "restore",
    "repositories"
  ],
  "license": "MIT"
}
