{
  "name": "github-gdrive-backup",
  "version": "3.5.0",
  "description": "Back up every GitHub repository to Google Drive — code, issues, PRs, releases, wiki, labels, milestones — and restore with one click.",
  "main": "src/server/app.js",
  "bin": {
    "gh-gdrive-backup": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/server/app.js",
    "backup": "node src/backup/index.js",
    "restore": "node src/restore/index.js",
    "dev": "nodemon src/server/app.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "test": "jest --forceExit --coverage",
    "test:watch": "jest --watch",
    "audit": "npm audit --audit-level=high",
    "check-headers": "node scripts/check-headers.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@azure/storage-blob": "^12.24.0",
    "@octokit/rest": "^20.1.1",
    "archiver": "^7.0.1",
    "axios": "^1.7.9",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "extract-zip": "^2.0.1",
    "googleapis": "^144.0.0",
    "multer": "^2.2.0",
    "simple-git": "^3.27.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.9"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 10
      }
    }
  },
  "keywords": [
    "github",
    "backup",
    "google-drive",
    "restore",
    "repositories",
    "cybersecurity",
    "data-resilience"
  ],
  "overrides": {
    "uuid": "^11.1.1"
  },
  "author": "Omar Rao <omarsrao@gmail.com>",
  "license": "MIT"
}
